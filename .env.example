# ============================================
# Environment Variables for Rowad Website
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ── reCAPTCHA (Required for contact form) ──
# Get keys from: https://www.google.com/recaptcha/admin/create
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key-here
RECAPTCHA_SECRET_KEY=your-secret-key-here

# ── Contact Form Endpoint (cPanel deployment) ──
# Option 1: PHP script on cPanel (default)
NEXT_PUBLIC_CONTACT_ENDPOINT=/contact-mailer.php
# Option 2: External service (uncomment to use)
# NEXT_PUBLIC_CONTACT_ENDPOINT=https://formspree.io/f/your-form-id

# ── SMTP Email (for local development with Next.js API) ──
# Used by nodemailer when running dev server
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ── Contact form recipient email ──
CONTACT_EMAIL=info@gsmdevops.com

# ── cPanel FTP Deployment (GitHub Actions secrets) ──
# Set these in GitHub Actions secrets, NOT in .env!
# CPANEL_FTP_HOST=ftp.yourdomain.com
# CPANEL_FTP_USERNAME=your-cpanel-username
# CPANEL_FTP_PASSWORD=your-cpanel-password
# CPANEL_DEPLOY_PATH=/public_html/

# ── Next.js (optional overrides) ──
# NODE_ENV=production
# NEXT_PUBLIC_SITE_URL=https://gsmdevops.com
